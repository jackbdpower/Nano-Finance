rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny everything else
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow read/write for system metadata and synchronized dataset ONLY to the verified server-sync admin
    match /nano_finance/{document} {
      allow read, write: if request.auth != null && request.auth.token.email == "server-sync@nanofinance.internal";
    }

    // Allow read/write for loan document base64 images ONLY to the verified server-sync admin
    match /nano_finance_docs/{document} {
      allow read, write: if request.auth != null && request.auth.token.email == "server-sync@nanofinance.internal";
    }
  }
}

